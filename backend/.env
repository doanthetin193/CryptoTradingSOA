# ===========================
# GLOBAL CONFIGURATION
# ===========================
NODE_ENV=development
LOG_LEVEL=info

# ===========================
# DATABASE CONFIGURATION
# ===========================
MONGODB_URI=mongodb+srv://doanthetindeveloper:doanthetin193@cluster0.g69mfzf.mongodb.net/crypto_trading_soa?retryWrites=true&w=majority&appName=Cluster0

# ===========================
# JWT CONFIGURATION
# ===========================
JWT_SECRET=your_super_secret_jwt_key_change_in_production_2025
JWT_EXPIRES_IN=7d

# ===========================
# CONSUL CONFIGURATION
# ===========================
CONSUL_HOST=localhost
CONSUL_PORT=8500

# ===========================
# SERVICE PORTS
# ===========================
API_GATEWAY_PORT=3000
USER_SERVICE_PORT=3001
MARKET_SERVICE_PORT=3002
PORTFOLIO_SERVICE_PORT=3003
TRADE_SERVICE_PORT=3004
NOTIFICATION_SERVICE_PORT=3005

# ===========================
# API GATEWAY CONFIGURATION
# ===========================
# Rate Limiting:
# - Global: 1000 requests / 15 minutes (all APIs)
# - Login: 5 attempts / 15 minutes
# - Register: 3 attempts / 60 minutes
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ===========================
# BUSINESS CONFIGURATION
# ===========================
INITIAL_BALANCE=1000
TRADING_FEE_PERCENTAGE=0.1
MIN_TRADE_AMOUNT_USD=10

# ===========================
# EMAIL CONFIGURATION (Optional)
# ===========================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=
ENABLE_EMAIL_NOTIFICATIONS=false

# ===========================
# WEBSOCKET CONFIGURATION
# ===========================
ENABLE_WEBSOCKET=true
ENABLE_PRICE_ALERTS=true

# ===========================
# MARKET SERVICE CONFIGURATION
# ===========================
COINGECKO_API_URL=https://api.coingecko.com/api/v3
SUPPORTED_COINS=bitcoin,ethereum,binancecoin,solana,ripple,cardano,dogecoin,polkadot

# Cache TTL (seconds) - Cache cao để tránh rate limit CoinGecko
CACHE_TTL_PRICES=300        # 5 minutes for price data
CACHE_TTL_CHART=3600        # 1 hour for chart data (tăng từ 10 phút)
